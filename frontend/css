body {
    font-family: Arial, sans-serif;
    background-color: #f5f5f5;
    text-align: center;
}

header {
    background-color: black;
    color: white;
    padding: 20px;
}

h1 {
    color: red;
}

.contenedor {
    background-color: white;
    margin: 30px auto;
    padding: 20px;
    width: 400px;
    border-radius: 10px;
    box-shadow: 0px 0px 10px gray;
}

.producto {
    margin: 10px;
}

.btn {
    background-color: green;
    color: white;
    padding: 10px 20px;
    border: none;
    font-size: 16px;
    border-radius: 5px;
    cursor: pointer;
}

.btn:hover {
    background-color: red;
}
